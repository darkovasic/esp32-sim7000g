menu "AT client"

    config AT_CLIENT_TASK_STACK
        int "Modem task stack (bytes)"
        default 4096

    config AT_CLIENT_TASK_PRIO
        int "Modem task priority"
        default 5

    config AT_CLIENT_QUEUE_DEPTH
        int "Command queue depth"
        range 1 8
        default 4

    config AT_CLIENT_DEFAULT_TIMEOUT_MS
        int "Default command timeout (ms)"
        default 3000

    config AT_CLIENT_MAX_LINE_LEN
        int "Max single line length (bytes)"
        default 256

    config AT_CLIENT_MAX_AGG_LEN
        int "Max aggregated response before OK/ERROR (bytes)"
        default 512

    config AT_CLIENT_DEFAULT_RETRIES
        int "Default retries on timeout/fail"
        range 0 5
        default 2

endmenu
