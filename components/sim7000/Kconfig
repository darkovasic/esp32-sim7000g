menu "SIM7000 modem"

    config SIM7000_DEFAULT_APN
        string "Default APN (used if NVS key modem/apn is unset)"
        default "internet"
        help
            Stored APN in NVS overrides this. Set your carrier APN for automatic PDP.

    config SIM7000_BRINGUP_PDP
        bool "Attach PDP context during sim7000_bringup()"
        default y
        help
            If disabled, only SIM + registration checks run (useful for UART-only lab).

    config SIM7000_PDP_CID
        int "PDP context id (CID)"
        range 1 16
        default 1

    config SIM7000_BRINGUP_USE_CGACT
        bool "Send AT+CGACT=1 after CGDCONT during bring-up"
        default n
        depends on SIM7000_BRINGUP_PDP
        help
            When off (default), bring-up only programs the APN with AT+CGDCONT; esp_modem then runs
            its own CGDCONT and ATD*99# for PPP. On some SIM7xxx/LTE networks, pre-activating with
            CGACT=1 leaves the context busy and PPP drops before IPCP (no IP). Enable this if your
            carrier requires explicit activation before the dial.

    config SIM7000_AT_TIMEOUT_MS
        int "esp_modem AT command timeout in sim7000_bringup() (ms)"
        default 3000

    config SIM7000_AT_RESP_MAX_LEN
        int "Max aggregated AT response buffer (bytes) in sim7000_bringup()"
        range 256 2048
        default 512

    config SIM7000_WAIT_FOR_REGISTRATION
        bool "Wait for network registration before PPP data mode"
        default y
        help
            When the ESP32 and modem power up together, the SIM can take tens of seconds to
            register while the MCU is already running AT + PPP. If PPP starts while CREG/CEREG
            still show \"searching\" (stat 2), LCP/IPCP often times out. This option polls
            AT+CREG? / AT+CGREG? / AT+CEREG? until stat is registered (1 or 5) or the timeout
            below is reached.

    config SIM7000_REGISTRATION_POLL_MS
        int "Registration poll interval (ms)"
        depends on SIM7000_WAIT_FOR_REGISTRATION
        default 3000
        range 1000 60000

    config SIM7000_REGISTRATION_TIMEOUT_MS
        int "Max wait for registration before PPP (ms)"
        depends on SIM7000_WAIT_FOR_REGISTRATION
        default 120000
        range 10000 600000

endmenu
